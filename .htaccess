# ============================================================
# .htaccess — Безопасность 7-Eleven Shop
# ============================================================

# ── Принудительный HTTPS ──────────────────────────────────────────────────
# Раскомментируйте когда будет SSL-сертификат:
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Защита конфиденциальных файлов и папок ─────────────────────────────────

# Запрет доступа к .env файлам
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Запрет доступа к конфигурационным файлам
<FilesMatch "\.(sql|log|bak|backup|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Запрет просмотра директорий
Options -Indexes

# Защита папки config/
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^backups/ - [F,L]
</IfModule>

# ── PHP настройки безопасности ─────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /var/log/php_errors.log

    # Secure session cookies
    php_flag session.cookie_httponly On
    php_flag session.cookie_secure On
    php_value session.cookie_samesite Strict
    php_flag session.use_strict_mode On
</IfModule>

# ── HTTP Security Headers ──────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS (включить после настройки HTTPS)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Блокировка опасных User-Agent ─────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (havij|sqlmap|nikto|nmap|masscan) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── Ограничение размера загружаемых файлов ─────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 8M
</IfModule>
